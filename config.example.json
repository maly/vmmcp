{
  "composeProjectDir": "/srv/example-app",
  "writableGlobs": [
    "nginx-vhost/*",
    "*.conf"
  ],
  "readableGlobs": [
    "docker-compose.yml",
    "nginx-vhost/*",
    "*.conf",
    "start",
    "update",
    "**/*.json"
  ],
  "denyGlobs": [
    ".ssh/*",
    "**/id_rsa*",
    "**/id_ed25519*"
  ],
  "envFiles": [
    ".env",
    "example.env"
  ],
  "envProtectedPatterns": [
    "*PASSWORD*",
    "*API_KEY*",
    "*SECRET*",
    "*TOKEN*",
    "*MONGO_URL*"
  ],
  "allowedScripts": [
    "start",
    "update"
  ]
}
